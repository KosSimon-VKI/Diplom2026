<Window x:Class="GardenNookWpf.Views.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GardenNookWpf.Views"
        mc:Ignorable="d"
        Title="Garden Nook" 
        Width="1500"
        Height="900"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize" 
        Icon="/Images/logo.png">

    <Window.Resources>
        <!-- Стиль для закруглённого TextBox -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="35"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderBrush" Value="#FF606E52"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для закруглённой Button -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="FontSize" Value="45"/>
            <Setter Property="Foreground" Value="#FF474747"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF606E52"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="35*"/>
            <ColumnDefinition Width="65*"/>
        </Grid.ColumnDefinitions>

        <!-- Правая панель: форма авторизации -->
        <Grid Grid.Column="1" Background="#FF91A56E">
            <Viewbox Stretch="Uniform" StretchDirection="Both">
                <StackPanel Width="975" Height="900">
                    <Label Content="Добро пожаловать!" 
                           FontSize="45" FontWeight="Black" 
                           HorizontalAlignment="Center" 
                           Margin="0,20,0,20" 
                           Foreground="#FF474747"/>

                    <Label Content="Введите логин:" 
                           Name="LoginLabel"
                           FontSize="45" 
                           HorizontalAlignment="Left" 
                           Margin="90,0,0,10" 
                           Foreground="#FF474747"/>

                    <TextBox Name="LoginBox" 
                             Style="{StaticResource RoundedTextBox}" 
                             MaxWidth="800" 
                             HorizontalAlignment="Stretch"/>

                    <Label Content="Введите пароль:"
                           Name="PasswordLabel"
                           FontSize="45" 
                           HorizontalAlignment="Left" 
                           Margin="90,20,0,10" 
                           Foreground="#FF474747"/>

                    <TextBox Name="PasswordBox" 
                             Style="{StaticResource RoundedTextBox}" 
                             MaxWidth="800" 
                             HorizontalAlignment="Stretch"/>

                    <Label Content="Неверный логин или пароль!" 
                           Name="ErrorLabel" 
                           FontSize="45" 
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"
                           Foreground="#FFE22D2D"/>

                    <Button Name="EnterButton" 
                            Content="Войти" 
                            Style="{StaticResource RoundedButton}" 
                            MaxWidth="400" 
                            HorizontalAlignment="Stretch" 
                            Margin="0,80,0,50" Click="EnterButton_Click"/>

                    <Button Name="BackButton" 
                            Content="Выход" 
                            Style="{StaticResource RoundedButton}" 
                            MaxWidth="400" 
                            HorizontalAlignment="Stretch" 
                            Click="BackButton_Click"/>
                </StackPanel>
            </Viewbox>
        </Grid>

        <!-- Левая панель: логотип и название -->
        <Grid Grid.Column="0">
            <Viewbox Stretch="Uniform" StretchDirection="Both">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="525" Height="500">
                    <Image Source="/Images/logo.png" MaxWidth="400" MaxHeight="400" Stretch="Uniform"/>
                    <Label Content="Garden Nook" 
                       FontSize="55" 
                       FontWeight="Black" 
                       HorizontalAlignment="Center" 
                       Foreground="#FF474747"
                       Margin="0,30,0,0"/>
                </StackPanel>
            </Viewbox>
        </Grid>
    </Grid>
</Window>